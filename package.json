{
  "name": "chat-keuangan-bench",
  "version": "0.8.0",
  "description": "Open benchmarks for Indonesian casual finance chat \u2014 Parse-25 (single-turn) + Rupiah-Pro (multi-turn agentic)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/volfadar/chat-keuangan-bench"
  },
  "keywords": [
    "indonesia",
    "rupiah",
    "finance",
    "llm",
    "benchmark",
    "evaluation",
    "whatsapp",
    "openrouter",
    "structured-extraction",
    "rupiah-pro",
    "agentic",
    "ledger"
  ],
  "scripts": {
    "eval": "bun run src/core/eval-core.ts",
    "eval:hard-12": "bun run scripts/eval-hard-12.ts",
    "eval:hard-25": "bun run scripts/eval-hard-25.ts",
    "eval:single": "bun run scripts/eval-hard-25-single.ts",
    "eval:scorecard": "bun run scripts/build-finance-model-scorecard.ts",
    "strip-csv": "bun run scripts/strip-openrouter-csv.ts",
    "eval:prompt-tune": "bun run scripts/eval-prompt-tune.ts",
    "eval:agentic": "bun run scripts/eval-agentic-hard-20.ts",
    "verify:agentic": "bun run scripts/verify-agentic-harness.ts",
    "fixtures:receipts": "bun run scripts/generate-receipt-fixtures.ts",
    "studio": "mastra dev --dir src/mastra",
    "report": "bun run scripts/generate-report-assets.ts",
    "report:rupiah-pro": "bun run scripts/generate-rupiah-pro-charts.ts",
    "analysis": "bun run scripts/generate-hard-25-analysis.ts",
    "bench:refresh": "bun run eval:scorecard && bun run report && bun run analysis",
    "dry-run": "bun run src/core/eval-core.ts --dry-run --limit 5",
    "rescore:agentic-v2": "bun run scripts/score-rupiah-pro.ts",
    "score:rupiah-pro": "bun run scripts/score-rupiah-pro.ts && bun run report:rupiah-pro"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@mastra/core": "1.50.1",
    "@mastra/evals": "1.5.1",
    "@mastra/libsql": "1.15.1",
    "@mastra/memory": "^1.22.2",
    "@mastra/observability": "1.16.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.176",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.7",
    "pdf-lib": "^1.17.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.0",
    "mastra": "1.18.2",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
