# Required for OpenRouter models (Gemini, Gemma, GLM, MiMo, Nemotron, etc.)
OPENROUTER_API_KEY=sk-or-v1-...

# Required for deepseek/deepseek-v4-pro via official API (recommended over OpenRouter)
DEEPSEEK_API_KEY=sk-...

# Rupiah-Pro (agentic) suite
FIRECRAWL_API_KEY=fc-...
JUDGE_MODEL=deepseek/deepseek-v4-pro
JUDGE_PROVIDER=DeepSeek
JUDGE_MODE=combined
JUDGE_REASONING_EFFORT=high
